# Tapo Configuration
TAPO_EMAIL=your_tapo_email@example.com
TAPO_PASSWORD=your_tapo_password
TAPO_DEVICE_IP=192.168.1.100

# Push Notifications (ntfy) - recommended
# Both phones: install the ntfy app and subscribe to the same topic
# Use a hard-to-guess topic name (e.g. dryer-finished-xK9m2pQ)
NTFY_TOPIC=your-secret-topic-name
NTFY_SERVER=https://ntfy.sh

# Email Configuration (Postmark) - optional
# Comma-separate multiple addresses: you@example.com,wife@example.com
EMAIL_FROM=noreply@yourdomain.com
EMAIL_TO=your_email@example.com
POSTMARK_API_TOKEN=your_postmark_api_token

# Monitoring Settings
HEATING_THRESHOLD=1500    # Watts - must see heating before alerting
OFF_THRESHOLD=50          # Watts - power below this counts toward "finished"
RUNNING_THRESHOLD=800     # Watts - used for status reporting
COOLDOWN_READINGS=3       # Consecutive off readings before alert
CHECK_INTERVAL=60         # Seconds between checks (60 = 1 min)

# Server Settings
PORT=3000
# API_KEY=your-secret-key   # Optional - protects /check, /status, /state, /reset
